<!DOCTYPE html>
<html lang="pt-br">

<head>

    <meta charset="UTF-8">

    <title>Editar Admin</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/static/style.css">

</head>

<body>

<header>
    Editar Admin
</header>

<nav>
    <a href="/admin">Voltar</a>
</nav>

<div class="container">

    <div class="card">

        <h2>Editar Dados</h2>

        <form method="POST">

            <input
                type="text"
                name="nome"
                value="{{admin[1]}}"
                required
            >

            <input
                type="email"
                name="email"
                value="{{admin[2]}}"
                required
            >

            <input
                type="text"
                name="senha"
                value="{{admin[3]}}"
                required
            >

            <button type="submit">
                Salvar Alterações
            </button>

        </form>

    </div>

</div>

</body>
</html>
